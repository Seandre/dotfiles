{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "black": "#000000",
    "white": "#FFFFFF",
    "text": "#FFFFFF",
    "muted": "#7c7c7c",
    "element": "#383a49",
    "selection": "#008000",
    "red": "#f44747",
    "comment": "#7ca668",
    "keyword": "#569cd6",
    "string": "#ce9178",
    "number": "#b5cea8",
    "function": "#DCDCAA",
    "operator": "#d4d4d4",
    "property": "#d7ba7d",
    "heading": "#6796e6",
    "type": "#4EC9B0",
    "variable": "#9CDCFE",
    "diffHeader": "#000080"
  },
  "theme": {
    "primary": {
      "dark": "selection",
      "light": "selection"
    },
    "secondary": {
      "dark": "keyword",
      "light": "keyword"
    },
    "accent": {
      "dark": "type",
      "light": "type"
    },
    "error": {
      "dark": "red",
      "light": "red"
    },
    "warning": {
      "dark": "property",
      "light": "property"
    },
    "success": {
      "dark": "number",
      "light": "number"
    },
    "info": {
      "dark": "keyword",
      "light": "keyword"
    },
    "text": {
      "dark": "white",
      "light": "white"
    },
    "textMuted": {
      "dark": "muted",
      "light": "muted"
    },
    "background": {
      "dark": "black",
      "light": "black"
    },
    "backgroundPanel": {
      "dark": "black",
      "light": "black"
    },
    "backgroundElement": {
      "dark": "element",
      "light": "element"
    },
    "border": {
      "dark": "white",
      "light": "white"
    },
    "borderActive": {
      "dark": "white",
      "light": "white"
    },
    "borderSubtle": {
      "dark": "muted",
      "light": "muted"
    },
    "diffAdded": {
      "dark": "number",
      "light": "number"
    },
    "diffRemoved": {
      "dark": "string",
      "light": "string"
    },
    "diffContext": {
      "dark": "muted",
      "light": "muted"
    },
    "diffHunkHeader": {
      "dark": "diffHeader",
      "light": "diffHeader"
    },
    "diffHighlightAdded": {
      "dark": "number",
      "light": "number"
    },
    "diffHighlightRemoved": {
      "dark": "string",
      "light": "string"
    },
    "diffAddedBg": {
      "dark": "black",
      "light": "black"
    },
    "diffRemovedBg": {
      "dark": "black",
      "light": "black"
    },
    "diffContextBg": {
      "dark": "black",
      "light": "black"
    },
    "diffLineNumber": {
      "dark": "muted",
      "light": "muted"
    },
    "diffAddedLineNumberBg": {
      "dark": "black",
      "light": "black"
    },
    "diffRemovedLineNumberBg": {
      "dark": "black",
      "light": "black"
    },
    "markdownText": {
      "dark": "text",
      "light": "text"
    },
    "markdownHeading": {
      "dark": "heading",
      "light": "heading"
    },
    "markdownLink": {
      "dark": "keyword",
      "light": "keyword"
    },
    "markdownLinkText": {
      "dark": "variable",
      "light": "variable"
    },
    "markdownCode": {
      "dark": "string",
      "light": "string"
    },
    "markdownBlockQuote": {
      "dark": "muted",
      "light": "muted"
    },
    "markdownEmph": {
      "dark": "property",
      "light": "property"
    },
    "markdownStrong": {
      "dark": "white",
      "light": "white"
    },
    "markdownHorizontalRule": {
      "dark": "white",
      "light": "white"
    },
    "markdownListItem": {
      "dark": "keyword",
      "light": "keyword"
    },
    "markdownListEnumeration": {
      "dark": "variable",
      "light": "variable"
    },
    "markdownImage": {
      "dark": "keyword",
      "light": "keyword"
    },
    "markdownImageText": {
      "dark": "variable",
      "light": "variable"
    },
    "markdownCodeBlock": {
      "dark": "text",
      "light": "text"
    },
    "syntaxComment": {
      "dark": "comment",
      "light": "comment"
    },
    "syntaxKeyword": {
      "dark": "keyword",
      "light": "keyword"
    },
    "syntaxFunction": {
      "dark": "function",
      "light": "function"
    },
    "syntaxVariable": {
      "dark": "variable",
      "light": "variable"
    },
    "syntaxString": {
      "dark": "string",
      "light": "string"
    },
    "syntaxNumber": {
      "dark": "number",
      "light": "number"
    },
    "syntaxType": {
      "dark": "type",
      "light": "type"
    },
    "syntaxOperator": {
      "dark": "operator",
      "light": "operator"
    },
    "syntaxPunctuation": {
      "dark": "text",
      "light": "text"
    }
  }
}
