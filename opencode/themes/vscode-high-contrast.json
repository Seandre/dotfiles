{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "black": "#000000",
    "panel": "#0a0a0a",
    "element": "#1e1e1e",
    "border": "#3a3a3a",
    "muted": "#666666",
    "text": "#f2f2f2",
    "white": "#ffffff",
    "red": "#cc241d",
    "brightRed": "#fb4934",
    "green": "#98971a",
    "brightGreen": "#b8bb26",
    "yellow": "#d79921",
    "brightYellow": "#fabd2f",
    "blue": "#458588",
    "brightBlue": "#83a598",
    "magenta": "#b16286",
    "brightMagenta": "#d3869b",
    "cyan": "#689d6a",
    "brightCyan": "#8ec07c",
    "diffAddedBg": "#102510",
    "diffRemovedBg": "#2a1010"
  },
  "theme": {
    "primary": {
      "dark": "brightBlue",
      "light": "brightBlue"
    },
    "secondary": {
      "dark": "brightMagenta",
      "light": "brightMagenta"
    },
    "accent": {
      "dark": "brightCyan",
      "light": "brightCyan"
    },
    "error": {
      "dark": "brightRed",
      "light": "brightRed"
    },
    "warning": {
      "dark": "brightYellow",
      "light": "brightYellow"
    },
    "success": {
      "dark": "brightGreen",
      "light": "brightGreen"
    },
    "info": {
      "dark": "brightBlue",
      "light": "brightBlue"
    },
    "text": {
      "dark": "text",
      "light": "text"
    },
    "textMuted": {
      "dark": "muted",
      "light": "muted"
    },
    "background": {
      "dark": "black",
      "light": "black"
    },
    "backgroundPanel": {
      "dark": "black",
      "light": "black"
    },
    "backgroundElement": {
      "dark": "element",
      "light": "element"
    },
    "border": {
      "dark": "border",
      "light": "border"
    },
    "borderActive": {
      "dark": "muted",
      "light": "muted"
    },
    "borderSubtle": {
      "dark": "element",
      "light": "element"
    },
    "diffAdded": {
      "dark": "brightGreen",
      "light": "brightGreen"
    },
    "diffRemoved": {
      "dark": "brightRed",
      "light": "brightRed"
    },
    "diffContext": {
      "dark": "muted",
      "light": "muted"
    },
    "diffHunkHeader": {
      "dark": "brightBlue",
      "light": "brightBlue"
    },
    "diffHighlightAdded": {
      "dark": "brightGreen",
      "light": "brightGreen"
    },
    "diffHighlightRemoved": {
      "dark": "brightRed",
      "light": "brightRed"
    },
    "diffAddedBg": {
      "dark": "diffAddedBg",
      "light": "diffAddedBg"
    },
    "diffRemovedBg": {
      "dark": "diffRemovedBg",
      "light": "diffRemovedBg"
    },
    "diffContextBg": {
      "dark": "panel",
      "light": "panel"
    },
    "diffLineNumber": {
      "dark": "muted",
      "light": "muted"
    },
    "diffAddedLineNumberBg": {
      "dark": "diffAddedBg",
      "light": "diffAddedBg"
    },
    "diffRemovedLineNumberBg": {
      "dark": "diffRemovedBg",
      "light": "diffRemovedBg"
    },
    "markdownText": {
      "dark": "text",
      "light": "text"
    },
    "markdownHeading": {
      "dark": "brightBlue",
      "light": "brightBlue"
    },
    "markdownLink": {
      "dark": "brightBlue",
      "light": "brightBlue"
    },
    "markdownLinkText": {
      "dark": "brightCyan",
      "light": "brightCyan"
    },
    "markdownCode": {
      "dark": "brightGreen",
      "light": "brightGreen"
    },
    "markdownBlockQuote": {
      "dark": "muted",
      "light": "muted"
    },
    "markdownEmph": {
      "dark": "brightYellow",
      "light": "brightYellow"
    },
    "markdownStrong": {
      "dark": "white",
      "light": "white"
    },
    "markdownHorizontalRule": {
      "dark": "border",
      "light": "border"
    },
    "markdownListItem": {
      "dark": "brightBlue",
      "light": "brightBlue"
    },
    "markdownListEnumeration": {
      "dark": "brightCyan",
      "light": "brightCyan"
    },
    "markdownImage": {
      "dark": "brightBlue",
      "light": "brightBlue"
    },
    "markdownImageText": {
      "dark": "brightCyan",
      "light": "brightCyan"
    },
    "markdownCodeBlock": {
      "dark": "text",
      "light": "text"
    },
    "syntaxComment": {
      "dark": "muted",
      "light": "muted"
    },
    "syntaxKeyword": {
      "dark": "brightBlue",
      "light": "brightBlue"
    },
    "syntaxFunction": {
      "dark": "brightCyan",
      "light": "brightCyan"
    },
    "syntaxVariable": {
      "dark": "text",
      "light": "text"
    },
    "syntaxString": {
      "dark": "brightGreen",
      "light": "brightGreen"
    },
    "syntaxNumber": {
      "dark": "brightMagenta",
      "light": "brightMagenta"
    },
    "syntaxType": {
      "dark": "brightCyan",
      "light": "brightCyan"
    },
    "syntaxOperator": {
      "dark": "brightBlue",
      "light": "brightBlue"
    },
    "syntaxPunctuation": {
      "dark": "text",
      "light": "text"
    }
  }
}
