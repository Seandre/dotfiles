  "editor.tokenColorCustomizations": {
    "[Default High Contrast]": {
      "comments": "#94a3b8",
      "strings": "#4ade80",
      "numbers": "#c084fc",
      "keywords": "#7dd3fc",
      "functions": "#5eead4",
      "variables": "#f8fafc",
      "types": "#93c5fd",
      "textMateRules": [
        {
          "scope": [
            "constant",
            "constant.language",
            "constant.character"
          ],
          "settings": {
            "foreground": "#c084fc"
          }
        },
        {
          "scope": [
            "keyword.operator",
            "punctuation"
          ],
          "settings": {
            "foreground": "#e5e7eb"
          }
        },
        {
          "scope": [
            "entity.name.tag",
            "support.type.property-name"
          ],
          "settings": {
            "foreground": "#7dd3fc"
          }
        },
        {
          "scope": [
            "markup.heading"
          ],
          "settings": {
            "foreground": "#7dd3fc",
            "fontStyle": "bold"
          }
        },
        {
          "scope": [
            "markup.bold"
          ],
          "settings": {
            "foreground": "#ffffff",
            "fontStyle": "bold"
          }
        },
        {
          "scope": [
            "markup.italic"
          ],
          "settings": {
            "foreground": "#facc15",
            "fontStyle": "italic"
          }
        },
        {
          "scope": [
            "markup.inline.raw",
            "markup.fenced_code.block"
          ],
          "settings": {
            "foreground": "#4ade80"
          }
        }
      ]
    }
  }
