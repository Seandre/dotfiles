  "editor.tokenColorCustomizations": {
    "[Default High Contrast]": {
      "comments": "#91949f",
      "strings": "#b4d4aa",
      "numbers": "#beb0b5",
      "keywords": "#98aed9",
      "functions": "#a5cfca",
      "variables": "#ced5e5",
      "types": "#8999b6",
      "textMateRules": [
        {
          "scope": [
            "constant",
            "constant.language",
            "constant.character"
          ],
          "settings": {
            "foreground": "#beb0b5"
          }
        },
        {
          "scope": [
            "keyword.operator",
            "punctuation"
          ],
          "settings": {
            "foreground": "#ced5e5"
          }
        },
        {
          "scope": [
            "entity.name.tag",
            "support.type.property-name"
          ],
          "settings": {
            "foreground": "#98aed9"
          }
        },
        {
          "scope": [
            "markup.heading"
          ],
          "settings": {
            "foreground": "#98aed9",
            "fontStyle": "bold"
          }
        },
        {
          "scope": [
            "markup.bold"
          ],
          "settings": {
            "foreground": "#ffffff",
            "fontStyle": "bold"
          }
        },
        {
          "scope": [
            "markup.italic"
          ],
          "settings": {
            "foreground": "#d6bf7a",
            "fontStyle": "italic"
          }
        },
        {
          "scope": [
            "markup.inline.raw",
            "markup.fenced_code.block"
          ],
          "settings": {
            "foreground": "#b4d4aa"
          }
        }
      ]
    }
  }
