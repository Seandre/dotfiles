  "editor.tokenColorCustomizations": {
    "[Default High Contrast]": {
      "comments": "#8a929e",
      "strings": "#8fbf9f",
      "numbers": "#b49ac8",
      "keywords": "#b6c7d8",
      "functions": "#8bbdb7",
      "variables": "#f2f4f7",
      "types": "#9fb4c9",
      "textMateRules": [
        {
          "scope": [
            "constant",
            "constant.language",
            "constant.character"
          ],
          "settings": {
            "foreground": "#b49ac8"
          }
        },
        {
          "scope": [
            "keyword.operator",
            "punctuation"
          ],
          "settings": {
            "foreground": "#d5dae1"
          }
        },
        {
          "scope": [
            "entity.name.tag",
            "support.type.property-name"
          ],
          "settings": {
            "foreground": "#b6c7d8"
          }
        },
        {
          "scope": [
            "markup.heading"
          ],
          "settings": {
            "foreground": "#b6c7d8",
            "fontStyle": "bold"
          }
        },
        {
          "scope": [
            "markup.bold"
          ],
          "settings": {
            "foreground": "#ffffff",
            "fontStyle": "bold"
          }
        },
        {
          "scope": [
            "markup.italic"
          ],
          "settings": {
            "foreground": "#d6bf7a",
            "fontStyle": "italic"
          }
        },
        {
          "scope": [
            "markup.inline.raw",
            "markup.fenced_code.block"
          ],
          "settings": {
            "foreground": "#8fbf9f"
          }
        }
      ]
    }
  }
