  "editor.tokenColorCustomizations": {
    "[Dark Modern]": {
      "comments": "#928374",
      "strings": "#b8bb26",
      "numbers": "#d3869b",
      "keywords": "#fb4934",
      "functions": "#fabd2f",
      "variables": "#ffffff",
      "types": "#fabd2f",
      "textMateRules": [
        {
          "scope": [
            "comment",
            "punctuation.definition.comment"
          ],
          "settings": {
            "foreground": "#928374",
            "fontStyle": "italic"
          }
        },
        {
          "scope": [
            "string",
            "string.quoted",
            "string.template"
          ],
          "settings": {
            "foreground": "#b8bb26"
          }
        },
        {
          "scope": [
            "constant.numeric",
            "constant.language.boolean",
            "constant.language.null"
          ],
          "settings": {
            "foreground": "#d3869b"
          }
        },
        {
          "scope": [
            "constant",
            "constant.character",
            "variable.other.constant"
          ],
          "settings": {
            "foreground": "#d65d0e"
          }
        },
        {
          "scope": [
            "keyword",
            "storage.type",
            "storage.modifier"
          ],
          "settings": {
            "foreground": "#fb4934"
          }
        },
        {
          "scope": [
            "keyword.operator",
            "punctuation",
            "punctuation.definition",
            "punctuation.separator"
          ],
          "settings": {
            "foreground": "#ffffff"
          }
        },
        {
          "scope": [
            "entity.name.function",
            "support.function",
            "meta.function-call"
          ],
          "settings": {
            "foreground": "#fabd2f"
          }
        },
        {
          "scope": [
            "entity.name.type",
            "entity.name.class",
            "support.type",
            "support.class"
          ],
          "settings": {
            "foreground": "#fabd2f"
          }
        },
        {
          "scope": [
            "entity.name.namespace",
            "entity.name.module",
            "support.type.primitive"
          ],
          "settings": {
            "foreground": "#83a598"
          }
        },
        {
          "scope": [
            "variable",
            "variable.other",
            "variable.parameter"
          ],
          "settings": {
            "foreground": "#ffffff"
          }
        },
        {
          "scope": [
            "variable.other.property",
            "support.variable.property",
            "meta.object-literal.key",
            "support.type.property-name"
          ],
          "settings": {
            "foreground": "#83a598"
          }
        },
        {
          "scope": [
            "entity.name.tag",
            "support.class.component"
          ],
          "settings": {
            "foreground": "#83a598"
          }
        },
        {
          "scope": [
            "entity.other.attribute-name",
            "support.type.vendored.property-name"
          ],
          "settings": {
            "foreground": "#8ec07c"
          }
        },
        {
          "scope": [
            "invalid",
            "invalid.illegal"
          ],
          "settings": {
            "foreground": "#fb4934"
          }
        },
        {
          "scope": [
            "markup.heading"
          ],
          "settings": {
            "foreground": "#fabd2f",
            "fontStyle": "bold"
          }
        },
        {
          "scope": [
            "markup.bold"
          ],
          "settings": {
            "foreground": "#ffffff",
            "fontStyle": "bold"
          }
        },
        {
          "scope": [
            "markup.italic"
          ],
          "settings": {
            "foreground": "#d3869b",
            "fontStyle": "italic"
          }
        },
        {
          "scope": [
            "markup.inline.raw",
            "markup.fenced_code.block"
          ],
          "settings": {
            "foreground": "#b8bb26"
          }
        }
      ]
    }
  }
}
