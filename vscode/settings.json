  "editor.tokenColorCustomizations": {
    "[Default High Contrast]": {
      "comments": "#666666",
      "strings": "#b8bb26",
      "numbers": "#d3869b",
      "keywords": "#83a598",
      "functions": "#8ec07c",
      "variables": "#f2f2f2",
      "types": "#8ec07c",
      "textMateRules": [
        {
          "scope": [
            "constant",
            "constant.language",
            "constant.character"
          ],
          "settings": {
            "foreground": "#d3869b"
          }
        },
        {
          "scope": [
            "keyword.operator",
            "punctuation"
          ],
          "settings": {
            "foreground": "#d4d4d4"
          }
        },
        {
          "scope": [
            "entity.name.tag",
            "support.type.property-name"
          ],
          "settings": {
            "foreground": "#83a598"
          }
        },
        {
          "scope": [
            "markup.heading"
          ],
          "settings": {
            "foreground": "#83a598",
            "fontStyle": "bold"
          }
        },
        {
          "scope": [
            "markup.bold"
          ],
          "settings": {
            "foreground": "#ffffff",
            "fontStyle": "bold"
          }
        },
        {
          "scope": [
            "markup.italic"
          ],
          "settings": {
            "foreground": "#fabd2f",
            "fontStyle": "italic"
          }
        },
        {
          "scope": [
            "markup.inline.raw",
            "markup.fenced_code.block"
          ],
          "settings": {
            "foreground": "#b8bb26"
          }
        }
      ]
    }
  }
